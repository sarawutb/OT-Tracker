<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="OTTracker.Controls.AppTabBar"
    x:Name="AnimatedContainer"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Grid
        Padding="8,8,8,14"
        BackgroundColor="{StaticResource Surface}">
        <Border
            Padding="14,7"
            BackgroundColor="{StaticResource Accent}"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 16">
            <Grid
                ColumnDefinitions="*,*,*"
                ColumnSpacing="4"
                HeightRequest="54">
                <Grid
                    x:Name="DashboardTab"
                    Grid.Column="0"
                    HeightRequest="54">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="DashboardTapped" />
                    </Grid.GestureRecognizers>
                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        Spacing="2"
                        VerticalOptions="Center">
                        <Path
                            x:Name="DashboardIcon"
                            Aspect="Uniform"
                            Data="M3 10.5 L12 3 L21 10.5 M5.5 9.5 V21 H10 V15 H14 V21 H18.5 V9.5"
                            HeightRequest="20"
                            StrokeLineCap="Round"
                            StrokeLineJoin="Round"
                            StrokeThickness="2"
                            WidthRequest="20" />
                        <Label
                            x:Name="DashboardLabel"
                            FontFamily="OpenSansSemibold"
                            FontSize="10"
                            HorizontalTextAlignment="Center"
                            Text="Home"
                            VerticalTextAlignment="Center" />
                        <Ellipse
                            x:Name="DashboardDot"
                            HeightRequest="4"
                            HorizontalOptions="Center"
                            WidthRequest="4" />
                    </VerticalStackLayout>
                </Grid>

                <Grid
                    x:Name="LogTab"
                    Grid.Column="1"
                    HeightRequest="54">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="LogTapped" />
                    </Grid.GestureRecognizers>
                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        Spacing="2"
                        VerticalOptions="Center">
                        <Border
                            x:Name="LogIconFrame"
                            BackgroundColor="Transparent"
                            HeightRequest="50"
                            Stroke="White"
                            StrokeThickness="2"
                            StrokeShape="RoundRectangle 30"
                            WidthRequest="50">
                            <Path
                                x:Name="LogIcon"
                                Aspect="Uniform"
                                Data="M12 5 V19 M5 12 H19"
                                HeightRequest="16"
                                HorizontalOptions="Center"
                                StrokeLineCap="Round"
                                StrokeLineJoin="Round"
                                StrokeThickness="2.4"
                                VerticalOptions="Center"
                                WidthRequest="16" />
                        </Border>
                        <Label
                            IsVisible="False"
                            x:Name="LogLabel"
                            FontFamily="OpenSansSemibold"
                            FontSize="10"
                            HorizontalTextAlignment="Center"
                            Text="Add OT"
                            VerticalTextAlignment="Center" />
                        <Ellipse 
                            IsVisible="False"
                            x:Name="LogDot"
                            HeightRequest="4"
                            HorizontalOptions="Center"
                            WidthRequest="4" />
                    </VerticalStackLayout>
                </Grid>

                <Grid
                    x:Name="SettingsTab"
                    Grid.Column="2"
                    HeightRequest="54">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="SettingsTapped" />
                    </Grid.GestureRecognizers>
                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        Spacing="2"
                        VerticalOptions="Center">
                        <Path
                            x:Name="SettingsIcon"
                            Aspect="Uniform"
                            Data="M12 12 C14.2 12 16 10.2 16 8 C16 5.8 14.2 4 12 4 C9.8 4 8 5.8 8 8 C8 10.2 9.8 12 12 12 Z M5 20 C6.2 16.8 8.7 15 12 15 C15.3 15 17.8 16.8 19 20"
                            HeightRequest="20"
                            StrokeLineCap="Round"
                            StrokeLineJoin="Round"
                            StrokeThickness="2"
                            WidthRequest="20" />
                        <Label
                            x:Name="SettingsLabel"
                            FontFamily="OpenSansSemibold"
                            FontSize="10"
                            HorizontalTextAlignment="Center"
                            Text="Settings"
                            VerticalTextAlignment="Center" />
                        <Ellipse
                            x:Name="SettingsDot"
                            HeightRequest="4"
                            HorizontalOptions="Center"
                            WidthRequest="4" />
                    </VerticalStackLayout>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</ContentView>
