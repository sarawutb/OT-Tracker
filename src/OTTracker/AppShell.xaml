<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="OTTracker.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:OTTracker.Views"
    BackgroundColor="{StaticResource AppBackground}"
    Shell.FlyoutBehavior="Disabled"
    Shell.TabBarBackgroundColor="{StaticResource Accent}"
    Shell.TabBarForegroundColor="{StaticResource Surface}"
    Shell.TabBarTitleColor="{StaticResource Surface}"
    Shell.TabBarUnselectedColor="{StaticResource AccentLight}"
    Title="OT Tracker">

    <ShellContent
        Title="Home"
        Route="Dashboard"
        ContentTemplate="{DataTemplate views:DashboardPage}" />
    <ShellContent
        Title="Log OT"
        Route="Log"
        ContentTemplate="{DataTemplate views:LogEntryPage}" />
    <ShellContent
        Title="History"
        Route="History"
        ContentTemplate="{DataTemplate views:HistoryPage}" />
    <ShellContent
        Title="Settings"
        Route="Settings"
        ContentTemplate="{DataTemplate views:SettingsPage}" />
</Shell>
