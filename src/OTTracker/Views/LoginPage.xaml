<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="OTTracker.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
    xmlns:m="clr-namespace:UraniumUI.Icons.MaterialSymbols;assembly=UraniumUI.Icons.MaterialSymbols"
    BackgroundColor="{StaticResource AppBackground}"
    Shell.NavBarIsVisible="False">
    <Grid Padding="24" RowDefinitions="*,Auto,*">
        <Border Style="{StaticResource Card}" 
            Grid.Row="1">
            <VerticalStackLayout
            MaximumWidthRequest="420"
            Spacing="10"
            VerticalOptions="Center">
                <VerticalStackLayout HorizontalOptions="Center" Spacing="8">
                    <Image     
                        WidthRequest="100"    
                        HeightRequest="100"
                        Aspect="AspectFit"
                        Source="ot_tracker.png" />
                    <Label
                    FontFamily="OpenSansSemibold"
                    FontSize="25"
                    HorizontalTextAlignment="Center"
                    Text="OT Tracker"
                    TextColor="{StaticResource Ink}" />
                    <Label
                    HorizontalTextAlignment="Center"
                    Style="{StaticResource MutedLabel}"
                    Text="Sign in to sync your OT logs" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="12">
                    <material:TextField
                        Keyboard="Email"
                        Title="Email"
                        ReturnType="Next"
                        Text="{Binding Email}" />
                    <material:TextField
                        IsTextPredictionEnabled="True"
                        IsPassword="True"
                        Keyboard="Password"
                        Title="Password"
                        ReturnType="Done"
                        Text="{Binding Password}" >
                    </material:TextField>
                    
                    <Grid ColumnDefinitions="*" ColumnSpacing="10" Margin="0,10">
                        <material:ButtonView VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand"
                               TappedCommand="{Binding SignInCommand}"
                               IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}">
                            <HorizontalStackLayout HorizontalOptions="CenterAndExpand" VerticalOptions="CenterAndExpand">
                                <Label FontAttributes="Bold" TextColor="White" VerticalOptions="Center" Text="Sign in"></Label>
                                <ActivityIndicator
                                    Margin="10,0,0,0"
                                    Color="{StaticResource White}"
                                    WidthRequest="20"
                                    HeightRequest="20"
                                    VerticalOptions="Center" 
                                    HorizontalOptions="Center"
                                    IsRunning="{Binding IsBusy}"
                                    IsVisible="{Binding IsBusy}" />
                            </HorizontalStackLayout>
                        </material:ButtonView>
                    </Grid>

                    <VerticalStackLayout
                        Margin="0,0,0,5"
                        VerticalOptions="End"
                        HorizontalOptions="Center"
                        Spacing="4">
                        <Label
                            HorizontalTextAlignment="Center"
                            Style="{StaticResource MutedLabel}"
                            Text="{Binding BiometricHint}" />
                        <Label
                            Text="{Binding AppVersion}"
                            FontSize="12"
                            FontAttributes="Bold"
                            HorizontalTextAlignment="Center"
                            TextColor="{StaticResource Ink2}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
