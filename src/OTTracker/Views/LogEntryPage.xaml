<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="OTTracker.Views.LogEntryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:OTTracker.Controls"
    xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
    xmlns:m="clr-namespace:UraniumUI.Icons.MaterialSymbols;assembly=UraniumUI.Icons.MaterialSymbols"
    Title="Log OT"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">
    <Grid RowDefinitions="*,Auto,Auto">
        <ScrollView>
            <VerticalStackLayout Padding="18" Spacing="10">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Style="{StaticResource PageTitle}" Text="Add OT" />
                    <Label
                        Grid.Column="1"
                        Style="{StaticResource MutedLabel}"
                        Text="Draft"
                        VerticalOptions="Center" />
                </Grid>

                <Label Style="{StaticResource MutedLabel}" Text="Date" />
                <material:DatePickerField
                    Title="Date"
                    Icon="{FontImageSource FontFamily=MaterialOutlined,
                                           Glyph={x:Static m:MaterialOutlined.Calendar_month}}"
                    Date="{Binding EntryDate, Mode=TwoWay}"
                    AllowClear="False" />

                <Label Style="{StaticResource MutedLabel}" Text="Day type" />
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="7">
                    
                    <Button
                        Command="{Binding SelectDayTypeCommand}"
                        CommandParameter="Regular"
                        FontSize="12"
                        Style="{StaticResource GhostButton}"
                        Text="x1.5 Regular">

                        <Button.Triggers>
                            <DataTrigger
                                Binding="{Binding SelectedDayType}"
                                TargetType="Button"
                                Value="Regular">
                                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                <Setter Property="TextColor" Value="White" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <Button
                        Grid.Column="1"
                        Command="{Binding SelectDayTypeCommand}"
                        CommandParameter="Weekend"
                        FontSize="12"
                        Style="{StaticResource GhostButton}"
                        Text="x2.0 Weekend">

                        <Button.Triggers>
                            <DataTrigger
                                Binding="{Binding SelectedDayType}"
                                TargetType="Button"
                                Value="Weekend">
                                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                <Setter Property="TextColor" Value="White" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <Button
                        Grid.Column="2"
                        Command="{Binding SelectDayTypeCommand}"
                        CommandParameter="Holiday"
                        FontSize="12"
                        Style="{StaticResource GhostButton}"
                        Text="x3.0 Holiday">

                        <Button.Triggers>
                            <DataTrigger
                                Binding="{Binding SelectedDayType}"
                                TargetType="Button"
                                Value="Holiday">
                                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                <Setter Property="TextColor" Value="White" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <VerticalStackLayout>
                        <Label Style="{StaticResource MutedLabel}" Text="Start time" />

                        <material:TimePickerField Margin="0,10" Title="Time" Icon="{FontImageSource FontFamily=MaterialOutlined, Glyph={x:Static m:MaterialOutlined.Calendar_clock}}" Time="{Binding StartTime}" AllowClear="False"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1">
                        <Label Style="{StaticResource MutedLabel}" Text="End time" />

                        <material:TimePickerField Margin="0,10" Title="Time" Icon="{FontImageSource FontFamily=MaterialOutlined, Glyph={x:Static m:MaterialOutlined.Calendar_clock}}" Time="{Binding EndTime}" AllowClear="False"/>
                    </VerticalStackLayout>
                </Grid>

                <material:TextField
                        Title="Break minutes"
                        Icon="{FontImageSource FontFamily=MaterialOutlined, Glyph={x:Static m:MaterialOutlined.Clock_loader_10}}"
                        Keyboard="Numeric"
                        Text="{Binding BreakMinutes}" />

                    <Label Style="{StaticResource MutedLabel}" Text="Note" />
                <material:EditorField Title="Task or project name..." Text="{Binding Note}"/>
                <Label
                    FontSize="12"
                    Text="{Binding ErrorMessage}"
                    TextColor="{StaticResource Red}" />
            </VerticalStackLayout>
        </ScrollView>

        <Border
            Grid.Row="1"
            Padding="18,14"
            BackgroundColor="{StaticResource Surface}"
            Stroke="{StaticResource Border}"
            StrokeThickness="1">
            <VerticalStackLayout Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Style="{StaticResource MutedLabel}" Text="Net OT hours" />
                    <Label
                        Grid.Column="1"
                        FontFamily="OpenSansSemibold"
                        Text="{Binding NetHoursText}"
                        TextColor="{StaticResource Ink}" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto">
                    <Label Style="{StaticResource MutedLabel}" Text="{Binding MultiplierText}" />
                    <Label
                        Grid.Column="1"
                        FontFamily="OpenSansSemibold"
                        Text="{Binding RateText}"
                        TextColor="{StaticResource Ink}" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto">
                    <Label Style="{StaticResource MutedLabel}" Text="Estimated earnings" />
                    <Label
                        Grid.Column="1"
                        FontFamily="OpenSansSemibold"
                        FontSize="22"
                        Text="{Binding EarningsText}"
                        TextColor="{StaticResource GreenMid}" />
                </Grid>
                <Button
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButton}"
                    Text="Save" />
            </VerticalStackLayout>
        </Border>
        <!--<controls:AppTabBar Grid.Row="2" ActiveRoute="Log" />-->
    </Grid>
</ContentPage>
