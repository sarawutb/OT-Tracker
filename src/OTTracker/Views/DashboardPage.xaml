<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="OTTracker.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:OTTracker.Controls"
    Title="Home"
    Shell.TabBarIsVisible="False">
    <Grid RowDefinitions="*,Auto">
    <ScrollView Grid.Row="0">
        <VerticalStackLayout Padding="18,18,18,24" Spacing="12">
            <Grid ColumnDefinitions="*,44" RowDefinitions="Auto,Auto">
                <Label Style="{StaticResource MutedLabel}" Text="Good evening" />
                <Label
                    Grid.Row="1"
                    Style="{StaticResource PageTitle}"
                    Text="{Binding MonthText}" />
                <Border
                    Grid.RowSpan="2"
                    Grid.Column="1"
                    BackgroundColor="{StaticResource AccentLight}"
                    HeightRequest="42"
                    StrokeShape="RoundRectangle 21"
                    StrokeThickness="0"
                    WidthRequest="42">
                    <Label
                        FontFamily="OpenSansSemibold"
                        HorizontalOptions="Center"
                        Text="Rang"
                        TextColor="{StaticResource Accent}"
                        VerticalOptions="Center" />
                </Border>
            </Grid>

            <Border
                Padding="20"
                BackgroundColor="{StaticResource Accent}"
                StrokeShape="RoundRectangle 22"
                StrokeThickness="0">
                <VerticalStackLayout Spacing="8">
                    <Label
                        FontSize="11"
                        Text="TOTAL OT THIS MONTH"
                        TextColor="#CCFFFFFF" />
                    <HorizontalStackLayout Spacing="6">
                        <Label
                            FontFamily="OpenSansSemibold"
                            FontSize="42"
                            Text="{Binding TotalHoursText}"
                            TextColor="White" />
                        <Label
                            Margin="0,0,0,7"
                            FontSize="14"
                            Text="hours"
                            TextColor="#CCFFFFFF"
                            VerticalOptions="End" />
                    </HorizontalStackLayout>
                    <BoxView
                        Margin="0,6"
                        HeightRequest="1"
                        Color="#33FFFFFF" />
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout>
                            <Label
                                FontSize="11"
                                Text="ESTIMATED EARNINGS"
                                TextColor="#AAFFFFFF" />
                            <Label
                                FontFamily="OpenSansSemibold"
                                FontSize="20"
                                Text="{Binding EarningsText}"
                                TextColor="White" />
                        </VerticalStackLayout>
                        <Switch
                            Grid.Column="1"
                            IsToggled="{Binding MaskEarnings}"
                            OnColor="#AFA9EC"
                            ThumbColor="White" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Border Style="{StaticResource CompactCard}">
                    <VerticalStackLayout>
                        <Label Style="{StaticResource MutedLabel}" Text="This week" />
                        <Label
                            FontFamily="OpenSansSemibold"
                            FontSize="20"
                            Text="{Binding ThisWeekHours, StringFormat='{0:0.##} hrs'}"
                            TextColor="{StaticResource Ink}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource CompactCard}">
                    <VerticalStackLayout>
                        <Label Style="{StaticResource MutedLabel}" Text="Entries logged" />
                        <Label
                            FontFamily="OpenSansSemibold"
                            FontSize="20"
                            Text="{Binding ThisWeekEntries, StringFormat='{0} days'}"
                            TextColor="{StaticResource Ink}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label
                            Margin="0"
                            Style="{StaticResource SectionTitle}"
                            Text="This week" />
                        <Border
                            Grid.Column="1"
                            Padding="10,4"
                            BackgroundColor="{StaticResource AccentLight}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="0">
                            <Label
                                FontSize="11"
                                Text="Mon-Sun"
                                TextColor="{StaticResource Accent}" />
                        </Border>
                    </Grid>
                    <CollectionView HeightRequest="96" ItemsSource="{Binding WeeklySummaries}">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout ItemSpacing="6" Orientation="Horizontal" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout
                                    Spacing="4"
                                    VerticalOptions="End"
                                    WidthRequest="38">
                                    <Label
                                        FontSize="10"
                                        HorizontalTextAlignment="Center"
                                        Text="{Binding Hours, StringFormat='{0:0.#}'}"
                                        TextColor="{StaticResource Ink2}" />
                                    <BoxView
                                        HeightRequest="{Binding Hours}"
                                        VerticalOptions="End"
                                        WidthRequest="26"
                                        Color="{StaticResource Accent}" />
                                    <Label
                                        FontSize="10"
                                        HorizontalTextAlignment="Center"
                                        Text="{Binding Day}"
                                        TextColor="{StaticResource MutedText}" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <HorizontalStackLayout Spacing="14">
                        <Label
                            FontSize="11"
                            Text="Weekday"
                            TextColor="{StaticResource Accent}" />
                        <Label
                            FontSize="11"
                            Text="Weekend"
                            TextColor="{StaticResource AmberMid}" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="8">
                    <Label
                        Margin="0,0,0,4"
                        Style="{StaticResource SectionTitle}"
                        Text="Recent entries" />
                    <CollectionView ItemsSource="{Binding RecentEntries}">
                        <CollectionView.EmptyView>
                            <Label Style="{StaticResource MutedLabel}" Text="No OT entries yet." />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid
                                    Padding="0,8"
                                    ColumnDefinitions="42,*,Auto"
                                    ColumnSpacing="10">
                                    <Border
                                        BackgroundColor="{StaticResource AccentLight}"
                                        HeightRequest="36"
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="0"
                                        WidthRequest="36">
                                        <Label
                                            FontSize="11"
                                            HorizontalOptions="Center"
                                            Text="OT"
                                            TextColor="{StaticResource Accent}"
                                            VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="1">
                                        <Label
                                            FontFamily="OpenSansSemibold"
                                            FontSize="12"
                                            Text="{Binding DateText}"
                                            TextColor="{StaticResource Ink}" />
                                        <Label
                                            FontSize="11"
                                            Text="{Binding TimeText}"
                                            TextColor="{StaticResource MutedText}" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout
                                        Grid.Column="2"
                                        HorizontalOptions="End"
                                        Spacing="1">
                                        <Label
                                            FontFamily="OpenSansSemibold"
                                            FontSize="13"
                                            HorizontalTextAlignment="End"
                                            Text="{Binding HoursText}"
                                            TextColor="{StaticResource Ink}" />
                                        <Label
                                            FontSize="11"
                                            HorizontalTextAlignment="End"
                                            Text="{Binding EarningsText}"
                                            TextColor="{StaticResource GreenMid}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,100" ColumnSpacing="8">
                <Button
                    Command="{Binding GoLogTodayCommand}"
                    Style="{StaticResource PrimaryButton}"
                    Text="Log today's OT" />
                <Button
                    Grid.Column="1"
                    Command="{Binding GoHistoryCommand}"
                    Style="{StaticResource GhostButton}"
                    Text="History" />
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
    <controls:AppTabBar Grid.Row="1" ActiveRoute="Dashboard" />
    </Grid>
</ContentPage>
