<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="OTTracker.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:OTTracker.Controls"
    xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
    Title="Settings"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">
    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0" IsVisible="{Binding IsBusy,Converter={StaticResource InverseBooleanConverter }}">
            <VerticalStackLayout Padding="18" Spacing="12">
                <Label Text="Settings" Style="{StaticResource PageTitle}" />

                <Label Text="PROFILE" Style="{StaticResource MutedLabel}" />
                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="10">
                        <material:TextField
                        Title="Username"
                        Text="{Binding UserName}" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="SALARY &amp; COMPENSATION" Style="{StaticResource MutedLabel}" />
                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="10">
                        <material:TextField
                        Title="Base monthly salary"
                        Keyboard="Numeric"
                        Text="{Binding BaseMonthlySalary}" />
                        <material:TextField
                        Title="Working days/month"
                        Keyboard="Numeric"
                        Text="{Binding WorkingDaysPerMonth}" />
                        <material:TextField
                        Title="Hours/day"
                        Keyboard="Numeric"
                        Text="{Binding HoursPerDay}" />
                        <material:TimePickerField
                        Title="Default start time"
                        AllowClear="False"
                        Time="{Binding DefaultStartTime}" />
                        <material:TimePickerField
                        Title="Default end time"
                        AllowClear="False"
                        Time="{Binding DefaultEndTime}" />
                        <material:TextField
                        Title="Default break minutes"
                        Keyboard="Numeric"
                        Text="{Binding DefaultBreakMinutes}" />
                        <Border BackgroundColor="{StaticResource GreenLight}" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="12">
                            <VerticalStackLayout>
                                <Label Text="HOURLY RATE" FontSize="10" TextColor="{StaticResource Green}" />
                                <Label Text="{Binding HourlyRateText}" FontSize="22" FontFamily="OpenSansSemibold" TextColor="{StaticResource Green}" />
                                <Label Text="{Binding FormulaText}" FontSize="11" TextColor="{StaticResource Green}" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Label Text="OT PERIOD" Style="{StaticResource MutedLabel}" />
                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <material:TextField
                            Title="Start day"
                            Keyboard="Numeric"
                            Text="{Binding PeriodStartDay}" />
                            <material:TextField
                            Grid.Column="1"
                            Title="End day"
                            Keyboard="Numeric"
                            Text="{Binding PeriodEndDay}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Label Text="OT MULTIPLIERS" Style="{StaticResource MutedLabel}" />
                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="10">
                        <material:TextField
                        Title="Regular workday"
                        Keyboard="Numeric"
                        Text="{Binding RegularMultiplier}" />
                        <material:TextField
                        Title="Weekend"
                        Keyboard="Numeric"
                        Text="{Binding WeekendMultiplier}" />
                        <material:TextField
                        Title="Public holiday"
                        Keyboard="Numeric"
                        Text="{Binding HolidayMultiplier}" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="SECURITY &amp; PRIVACY" Style="{StaticResource MutedLabel}" />
                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout>
                                <Label Text="PIN lock" TextColor="{StaticResource Ink}" />
                                <Label Text="Require PIN on launch" Style="{StaticResource MutedLabel}" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1" IsToggled="{Binding PinLockEnabled}" />
                        </Grid>
                        <Button Text="Change PIN" Command="{Binding ChangePinCommand}" />
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout>
                                <Label Text="Biometric unlock" TextColor="{StaticResource Ink}" />
                                <Label Text="Requires PIN lock and device fingerprint setup" Style="{StaticResource MutedLabel}" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1" IsToggled="{Binding BiometricUnlockEnabled}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Label Text="SUPABASE" Style="{StaticResource MutedLabel}" />
                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="10">
                        <material:TextField
                        Title="Project URL"
                        Keyboard="Url"
                        Text="{Binding SupabaseUrl}" />
                        <material:TextField
                        Title="Anon key"
                        Text="{Binding SupabaseAnonKey}" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button Text="Save connection" Command="{Binding SaveSupabaseConfigCommand}" Style="{StaticResource GhostButton}" />
                            <Button Grid.Column="1" Text="Sign out" Command="{Binding SignOutCommand}" Style="{StaticResource GhostButton}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Label Text="DATA" Style="{StaticResource MutedLabel}" />
                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="10">
                        <Button Text="Export to CSV" Command="{Binding ExportCommand}" Style="{StaticResource GhostButton}" />
                        <Button Text="Import from CSV" Command="{Binding ImportCommand}" Style="{StaticResource GhostButton}" />
                        <Button Text="Clear all data" Command="{Binding ClearDataCommand}" Style="{StaticResource GhostButton}" TextColor="{StaticResource Red}" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Red}" FontSize="12" />
                <Button Text="Save settings" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" />
            </VerticalStackLayout>
        </ScrollView>
        <controls:AppTabBar Grid.Row="1" ActiveRoute="Settings" />
    </Grid>
</ContentPage>
