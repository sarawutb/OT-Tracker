<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="OTTracker.Views.PinPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource AppBackground}"
    Shell.NavBarIsVisible="False">
    <Grid Padding="24" RowDefinitions="Auto,*,Auto">
        <VerticalStackLayout
            Grid.Row="0"
            Margin="0,52,0,20"
            HorizontalOptions="Center"
            Spacing="8">
            <Border
                BackgroundColor="{StaticResource AccentLight}"
                HeightRequest="80"
                StrokeShape="RoundRectangle 22"
                StrokeThickness="0"
                WidthRequest="80">
                <Image
                    Source="ot_tracker.png"
                    Aspect="AspectFit" />
            </Border>
            <Label
                FontFamily="OpenSansSemibold"
                FontSize="20"
                HorizontalTextAlignment="Center"
                Text="OT Tracker"
                TextColor="{StaticResource Ink}" />
            <Label
                HorizontalTextAlignment="Center"
                Style="{StaticResource MutedLabel}"
                Text="Enter your PIN to unlock" />
            <HorizontalStackLayout
                Margin="0,16,0,0"
                HorizontalOptions="Center"
                Spacing="18">
                <Border
                    x:Name="Dot1"
                    WidthRequest="18"
                    HeightRequest="18"
                    BackgroundColor="White"
                    Stroke="{StaticResource Ink}"
                    StrokeThickness="0.75"
                    StrokeShape="RoundRectangle 16">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding Dot1}" Value="●">
                            <Setter Property="BackgroundColor" Value="{StaticResource Ink}" />
                            <Setter Property="StrokeThickness" Value="0" />
                        </DataTrigger>
                    </Border.Triggers>
                </Border>
                <Border
                    x:Name="Dot2"
                    WidthRequest="18"
                    HeightRequest="18"
                    BackgroundColor="White"
                    Stroke="{StaticResource Ink}"
                    StrokeThickness="0.75"
                    StrokeShape="RoundRectangle 16">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding Dot2}" Value="●">
                            <Setter Property="BackgroundColor" Value="{StaticResource Ink}" />
                            <Setter Property="StrokeThickness" Value="0" />
                        </DataTrigger>
                    </Border.Triggers>
                </Border>
                <Border
                    x:Name="Dot3"
                    WidthRequest="18"
                    HeightRequest="18"
                    BackgroundColor="White"
                    Stroke="{StaticResource Ink}"
                    StrokeThickness="0.75"
                    StrokeShape="RoundRectangle 16">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding Dot3}" Value="●">
                            <Setter Property="BackgroundColor" Value="{StaticResource Ink}" />
                            <Setter Property="StrokeThickness" Value="0" />
                        </DataTrigger>
                    </Border.Triggers>
                </Border>
                <Border
                    x:Name="Dot4"
                    WidthRequest="18"
                    HeightRequest="18"
                    BackgroundColor="White"
                    Stroke="{StaticResource Ink}"
                    StrokeThickness="0.75"
                    StrokeShape="RoundRectangle 16">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding Dot4}" Value="●">
                            <Setter Property="BackgroundColor" Value="{StaticResource Ink}" />
                            <Setter Property="StrokeThickness" Value="0" />
                        </DataTrigger>
                    </Border.Triggers>
                </Border>
            </HorizontalStackLayout>
            <Label
                FontSize="12"
                HeightRequest="18"
                HorizontalTextAlignment="Center"
                Text="{Binding ErrorMessage}"
                TextColor="{StaticResource Red}" />
        </VerticalStackLayout>

        <Grid
            Grid.Row="1"
            ColumnDefinitions="*,*,*"
            ColumnSpacing="8"
            RowDefinitions="*,*,*,*"
            RowSpacing="8"
            VerticalOptions="Center">
            <Button
                Grid.Row="0"
                Grid.Column="0"
                Command="{Binding PressCommand}"
                CommandParameter="1"
                Style="{StaticResource PinKeyButton}"
                Text="1" />
            <Button
                Grid.Row="0"
                Grid.Column="1"
                Command="{Binding PressCommand}"
                CommandParameter="2"
                Style="{StaticResource PinKeyButton}"
                Text="2" />
            <Button
                Grid.Row="0"
                Grid.Column="2"
                Command="{Binding PressCommand}"
                CommandParameter="3"
                Style="{StaticResource PinKeyButton}"
                Text="3" />
            <Button
                Grid.Row="1"
                Grid.Column="0"
                Command="{Binding PressCommand}"
                CommandParameter="4"
                Style="{StaticResource PinKeyButton}"
                Text="4" />
            <Button
                Grid.Row="1"
                Grid.Column="1"
                Command="{Binding PressCommand}"
                CommandParameter="5"
                Style="{StaticResource PinKeyButton}"
                Text="5" />
            <Button
                Grid.Row="1"
                Grid.Column="2"
                Command="{Binding PressCommand}"
                CommandParameter="6"
                Style="{StaticResource PinKeyButton}"
                Text="6" />
            <Button
                Grid.Row="2"
                Grid.Column="0"
                Command="{Binding PressCommand}"
                CommandParameter="7"
                Style="{StaticResource PinKeyButton}"
                Text="7" />
            <Button
                Grid.Row="2"
                Grid.Column="1"
                Command="{Binding PressCommand}"
                CommandParameter="8"
                Style="{StaticResource PinKeyButton}"
                Text="8" />
            <Button
                Grid.Row="2"
                Grid.Column="2"
                Command="{Binding PressCommand}"
                CommandParameter="9"
                Style="{StaticResource PinKeyButton}"
                Text="9" />
            <ImageButton
                Grid.Row="3"
                Grid.Column="0"
                Command="{Binding UnlockBiometricCommand}"
                Source="fingerprint.png"
                Aspect="AspectFit"
                Style="{StaticResource GhostImageButton}"
              />
            <Button
                Grid.Row="3"
                Grid.Column="1"
                Command="{Binding PressCommand}"
                CommandParameter="0"
                Style="{StaticResource PinKeyButton}"
                Text="0" />
            <Button
                Grid.Row="3"
                Grid.Column="2"
                Command="{Binding BackspaceCommand}"
                Style="{StaticResource PinKeyButton}"
                Text="DEL" />
        </Grid>

        <VerticalStackLayout
            Grid.Row="2"
            Margin="0,16,0,24"
            HorizontalOptions="Center"
            Spacing="4">
            <Label
                HorizontalTextAlignment="Center"
                Style="{StaticResource MutedLabel}"
                Text="{Binding BiometricHint}" />
            <Label
                x:Name="AppVersionLabel"
                FontSize="12"
                FontAttributes="Bold"
                HorizontalTextAlignment="Center"
                TextColor="{StaticResource MutedLabel}" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
