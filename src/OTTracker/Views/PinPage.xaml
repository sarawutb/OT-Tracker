<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="OTTracker.Views.PinPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False">
    <Grid Padding="24" RowDefinitions="Auto,*,Auto">
        <VerticalStackLayout
            Grid.Row="0"
            Margin="0,52,0,20"
            HorizontalOptions="Center"
            Spacing="8">
            <Border
                BackgroundColor="{StaticResource AccentLight}"
                HeightRequest="64"
                StrokeShape="RoundRectangle 22"
                StrokeThickness="0"
                WidthRequest="64">
                <Label
                    FontFamily="OpenSansSemibold"
                    FontSize="20"
                    HorizontalOptions="Center"
                    Text="OT"
                    TextColor="{StaticResource Accent}"
                    VerticalOptions="Center" />
            </Border>
            <Label
                FontFamily="OpenSansSemibold"
                FontSize="20"
                HorizontalTextAlignment="Center"
                Text="OT Tracker"
                TextColor="{StaticResource Ink}" />
            <Label
                HorizontalTextAlignment="Center"
                Style="{StaticResource MutedLabel}"
                Text="Enter your PIN to unlock" />
            <HorizontalStackLayout
                Margin="0,16,0,0"
                HorizontalOptions="Center"
                Spacing="12">
                <Label
                    FontSize="22"
                    Text="{Binding Dot1}"
                    TextColor="{StaticResource Accent}" />
                <Label
                    FontSize="22"
                    Text="{Binding Dot2}"
                    TextColor="{StaticResource Accent}" />
                <Label
                    FontSize="22"
                    Text="{Binding Dot3}"
                    TextColor="{StaticResource Accent}" />
                <Label
                    FontSize="22"
                    Text="{Binding Dot4}"
                    TextColor="{StaticResource Accent}" />
            </HorizontalStackLayout>
            <Label
                FontSize="12"
                HeightRequest="18"
                HorizontalTextAlignment="Center"
                Text="{Binding ErrorMessage}"
                TextColor="{StaticResource Red}" />
        </VerticalStackLayout>

        <Grid
            Grid.Row="1"
            ColumnDefinitions="*,*,*"
            ColumnSpacing="8"
            RowDefinitions="*,*,*,*"
            RowSpacing="8"
            VerticalOptions="Center">
            <Button
                Grid.Row="0"
                Grid.Column="0"
                Command="{Binding PressCommand}"
                CommandParameter="1"
                FontSize="20"
                Style="{StaticResource GhostButton}"
                Text="1" />
            <Button
                Grid.Row="0"
                Grid.Column="1"
                Command="{Binding PressCommand}"
                CommandParameter="2"
                FontSize="20"
                Style="{StaticResource GhostButton}"
                Text="2" />
            <Button
                Grid.Row="0"
                Grid.Column="2"
                Command="{Binding PressCommand}"
                CommandParameter="3"
                FontSize="20"
                Style="{StaticResource GhostButton}"
                Text="3" />
            <Button
                Grid.Row="1"
                Grid.Column="0"
                Command="{Binding PressCommand}"
                CommandParameter="4"
                FontSize="20"
                Style="{StaticResource GhostButton}"
                Text="4" />
            <Button
                Grid.Row="1"
                Grid.Column="1"
                Command="{Binding PressCommand}"
                CommandParameter="5"
                FontSize="20"
                Style="{StaticResource GhostButton}"
                Text="5" />
            <Button
                Grid.Row="1"
                Grid.Column="2"
                Command="{Binding PressCommand}"
                CommandParameter="6"
                FontSize="20"
                Style="{StaticResource GhostButton}"
                Text="6" />
            <Button
                Grid.Row="2"
                Grid.Column="0"
                Command="{Binding PressCommand}"
                CommandParameter="7"
                FontSize="20"
                Style="{StaticResource GhostButton}"
                Text="7" />
            <Button
                Grid.Row="2"
                Grid.Column="1"
                Command="{Binding PressCommand}"
                CommandParameter="8"
                FontSize="20"
                Style="{StaticResource GhostButton}"
                Text="8" />
            <Button
                Grid.Row="2"
                Grid.Column="2"
                Command="{Binding PressCommand}"
                CommandParameter="9"
                FontSize="20"
                Style="{StaticResource GhostButton}"
                Text="9" />
            <!--<Button
                Grid.Row="3"
                Grid.Column="0"
                Command="{Binding PressCommand}"
                FontSize="20"
                Style="{StaticResource GhostButton}"
                Text="#" />-->
            <Button
                Grid.Row="3"
                Grid.Column="1"
                Command="{Binding PressCommand}"
                CommandParameter="0"
                FontSize="20"
                Style="{StaticResource GhostButton}"
                Text="0" />
            <Button
                Grid.Row="3"
                Grid.Column="2"
                Command="{Binding BackspaceCommand}"
                Style="{StaticResource GhostButton}"
                Text="DEL" />
        </Grid>

        <Label
            Grid.Row="2"
            Margin="0,16,0,24"
            HorizontalTextAlignment="Center"
            Style="{StaticResource MutedLabel}"
            Text="Use Face ID or fingerprint" />
    </Grid>
</ContentPage>
