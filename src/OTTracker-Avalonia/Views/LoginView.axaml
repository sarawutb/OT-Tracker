<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OTTracker_Avalonia.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="OTTracker_Avalonia.Views.LoginView"
             x:DataType="vm:LoginViewModel">

    <Grid Background="{DynamicResource BgAppBrush}">
        <!-- Glassmorphism Card Container -->
        <Border Classes="Card" 
                Width="380" Height="480" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                BoxShadow="0 10 30 0 #40000000"
                BorderThickness="1"
                BorderBrush="{DynamicResource BorderBrush}"
                Background="{DynamicResource BgWindowBrush}">
            
            <StackPanel Spacing="16" Margin="24">
                <!-- Header -->
                <TextBlock Text="🚀" 
                           FontSize="44" 
                           HorizontalAlignment="Center" 
                           Margin="0,10,0,0"/>
                
                <TextBlock Text="Welcome to OT Tracker" 
                           FontFamily="{StaticResource OutfitFont}" 
                           FontWeight="Bold" 
                           FontSize="20" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,2"/>

                <TextBlock Text="Sign in or register to sync your OT logs" 
                           FontFamily="{StaticResource InterFont}" 
                           FontSize="12" 
                           Foreground="{DynamicResource TextMutedBrush}" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,16"/>

                <!-- Email Input -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Email Address" 
                               FontFamily="{StaticResource InterFont}" 
                               FontSize="12" 
                               Foreground="{DynamicResource TextMutedBrush}"/>
                    <TextBox Text="{Binding Email}" 
                             PlaceholderText="username@example.com"
                             Background="{DynamicResource BgInputBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             CornerRadius="6"/>
                </StackPanel>

                <!-- Password Input -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Password" 
                               FontFamily="{StaticResource InterFont}" 
                               FontSize="12" 
                               Foreground="{DynamicResource TextMutedBrush}"/>
                    <TextBox Text="{Binding Password}" 
                             PasswordChar="*" 
                             PlaceholderText="••••••••"
                             Background="{DynamicResource BgInputBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             CornerRadius="6"/>
                </StackPanel>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}" 
                           FontFamily="{StaticResource InterFont}" 
                           FontSize="12" 
                           Foreground="{DynamicResource DangerBrush}" 
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Height="36"
                           IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <!-- Action Buttons -->
                <Grid ColumnDefinitions="*, *" Margin="0,10,0,0">
                    <Button Grid.Column="0" 
                            Content="Sign In" 
                            Classes="Primary" 
                            Command="{Binding SignInCommand}"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{Binding !IsBusy}"
                            Margin="0,0,6,0"/>
                    <Button Grid.Column="1" 
                            Content="Sign Up" 
                            Classes="Secondary" 
                            Command="{Binding SignUpCommand}"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{Binding !IsBusy}"
                            Margin="6,0,0,0"/>
                </Grid>

                <!-- Loading bar -->
                <ProgressBar IsIndeterminate="True" 
                             Height="4" 
                             IsVisible="{Binding IsBusy}" 
                             Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
