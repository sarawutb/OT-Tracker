<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OTTracker_Avalonia.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="OTTracker_Avalonia.Views.PinView"
             x:DataType="vm:PinViewModel">

    <Grid Background="{DynamicResource BgAppBrush}">
        <!-- Glassmorphism Card Container -->
        <Border Classes="Card" 
                Width="360"
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                BoxShadow="0 10 30 0 #40000000"
                BorderThickness="1"
                BorderBrush="{DynamicResource BorderBrush}"
                Background="{DynamicResource BgWindowBrush}">
            
            <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto">
                
                <!-- Icon Lock Header -->
				<Image Grid.Row="0" Source="/Assets/ottracker-logo.png" Height="100"/>
                <!--<materialIcons:MaterialIcon Grid.Row="0" Kind="Lock" Width="44" Height="44" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" Margin="0,20,0,10"/>-->
                
                <!-- Title -->
                <TextBlock Grid.Row="1" 
                           Text="Authentication Required" 
                           FontFamily="{StaticResource OutfitFont}" 
                           FontWeight="Bold" 
                           FontSize="18" 
                           HorizontalAlignment="Center" 
                           Margin="0,10,0,6"/>

                <TextBlock Grid.Row="2" 
                           Text="{Binding BiometricHint}" 
                           FontFamily="{StaticResource InterFont}" 
                           FontSize="13" 
                           Foreground="{DynamicResource TextMutedBrush}" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,24"/>

                <!-- PIN Indicator Dots -->
                <StackPanel Grid.Row="3" 
                            Orientation="Horizontal" 
                            Spacing="20" 
                            HorizontalAlignment="Center" 
                            Margin="0,0,0,12">
                    <TextBlock Text="{Binding Dot1}" FontSize="24" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding Dot2}" FontSize="24" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding Dot3}" FontSize="24" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding Dot4}" FontSize="24" Foreground="{DynamicResource AccentBrush}"/>
                </StackPanel>

                <!-- Error message display area -->
                <TextBlock Grid.Row="4" 
                           Text="{Binding ErrorMessage}" 
                           FontFamily="{StaticResource InterFont}" 
                           FontSize="12" 
                           Foreground="{DynamicResource DangerBrush}" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Top"
                           Margin="0,0,0,10"
                           Height="20"/>

                <!-- Visual 3x4 numeric keyboard keypad -->
                <Grid Grid.Row="4" 
                      RowDefinitions="*, *, *, *" 
                      ColumnDefinitions="*, *, *" 
                      Margin="20,40,20,10"
                      Height="250"
                      VerticalAlignment="Bottom">
                    
                    <!-- Row 1 -->
                    <Button Grid.Row="0" Grid.Column="0" Content="1" Classes="Secondary" Command="{Binding PressCommand}" CommandParameter="1" Margin="4" CornerRadius="30" FontSize="18"/>
                    <Button Grid.Row="0" Grid.Column="1" Content="2" Classes="Secondary" Command="{Binding PressCommand}" CommandParameter="2" Margin="4" CornerRadius="30" FontSize="18"/>
                    <Button Grid.Row="0" Grid.Column="2" Content="3" Classes="Secondary" Command="{Binding PressCommand}" CommandParameter="3" Margin="4" CornerRadius="30" FontSize="18"/>

                    <!-- Row 2 -->
                    <Button Grid.Row="1" Grid.Column="0" Content="4" Classes="Secondary" Command="{Binding PressCommand}" CommandParameter="4" Margin="4" CornerRadius="30" FontSize="18"/>
                    <Button Grid.Row="1" Grid.Column="1" Content="5" Classes="Secondary" Command="{Binding PressCommand}" CommandParameter="5" Margin="4" CornerRadius="30" FontSize="18"/>
                    <Button Grid.Row="1" Grid.Column="2" Content="6" Classes="Secondary" Command="{Binding PressCommand}" CommandParameter="6" Margin="4" CornerRadius="30" FontSize="18"/>

                    <!-- Row 3 -->
                    <Button Grid.Row="2" Grid.Column="0" Content="7" Classes="Secondary" Command="{Binding PressCommand}" CommandParameter="7" Margin="4" CornerRadius="30" FontSize="18"/>
                    <Button Grid.Row="2" Grid.Column="1" Content="8" Classes="Secondary" Command="{Binding PressCommand}" CommandParameter="8" Margin="4" CornerRadius="30" FontSize="18"/>
                    <Button Grid.Row="2" Grid.Column="2" Content="9" Classes="Secondary" Command="{Binding PressCommand}" CommandParameter="9" Margin="4" CornerRadius="30" FontSize="18"/>

                    <!-- Row 4 -->
                    <!-- Placeholder or clear button -->
                    <Border Grid.Row="3" Grid.Column="0" Margin="4"/>
                    <Button Grid.Row="3" Grid.Column="1" Content="0" Classes="Secondary" Command="{Binding PressCommand}" CommandParameter="0" Margin="4" CornerRadius="30" FontSize="18"/>
                    <Button Grid.Row="3" Grid.Column="2" Classes="Secondary" Command="{Binding BackspaceCommand}" Margin="4" CornerRadius="30">
                        <materialIcons:MaterialIcon Kind="Backspace" Width="18" Height="18" Foreground="{DynamicResource DangerBrush}"/>
                    </Button>
                </Grid>
				
				<!-- Version display area -->
				<TextBlock Grid.Row="5"
                           Text="{Binding VersionDisplay}"
                           FontFamily="{StaticResource InterFont}"
                           FontSize="12"
                           Foreground="{DynamicResource FontSizeLarge}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,10"
                           Height="20"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
